@prefix : <https://aopwiki.rdf.bigcat-bioinformatics.org/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix aop.events: <https://identifiers.org/aop.events/> .
@prefix aop.relationships: <https://identifiers.org/aop.relationships/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> . 
@prefix ensembl: <https://identifiers.org/ensembl/> .
@prefix edam: <http://edamontology.org/> .
@prefix hgnc: <https://identifiers.org/hgnc/>.
@prefix ncbigene: <https://identifiers.org/ncbigene/>.
@prefix uniprot: <https://identifiers.org/uniprot/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.

@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:BERN2NERMapping a prov:Activity ;
	rdfs:label "BERN2 NER+EL gene mapping -- featured recall-extending method (additive to the regex baseline, not an override; scored annotations filtered at minConfidence, unscored neural-normalised entities retained)" ;
	:isFeaturedMethod true ;
	:minConfidence "0.70"^^xsd:decimal ;
	prov:used <http://bern2.korea.ac.kr/plain> ;
	prov:wasDerivedFrom :AOPWikiXMLSource .

:RegexGeneMapping a prov:Activity ;
	rdfs:label "HGNC dictionary regex gene mapping -- baseline method that seeds and orders the edam:data_1025 union (never thinned on BERN2 outage)" ;
	:isFeaturedMethod false ;
	prov:used <https://www.genenames.org/> ;
	prov:wasDerivedFrom :AOPWikiXMLSource .

:AOPWikiXMLSource a prov:Entity ;
	rdfs:label "AOP-Wiki XML export" .

:geneDetectedByNER prov:wasGeneratedBy :BERN2NERMapping .
:geneDetectedByRegex prov:wasGeneratedBy :RegexGeneMapping .

:geneDetectedByNER rdfs:label "gene detected by BERN2 NER+EL (featured recall-extending method)" .
:geneDetectedByRegex rdfs:label "gene detected by HGNC dictionary regex (baseline method)" .
:isFeaturedMethod rdfs:label "is featured method (BERN2 primacy flag)" .
:minConfidence rdfs:label "minimum BERN2 annotation confidence retained" .

