@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:BERN2NERMapping a prov:Activity ;
	rdfs:label "BERN2 NER+EL gene mapping" ;
	:isFeaturedMethod true ;
	:minConfidence "0.70"^^xsd:decimal ;
	prov:used <http://bern2.korea.ac.kr/plain> ;
	prov:wasDerivedFrom :AOPWikiXMLSource .

:RegexGeneMapping a prov:Activity ;
	rdfs:label "HGNC dictionary regex gene mapping" ;
	:isFeaturedMethod false ;
	prov:used <https://www.genenames.org/> ;
	prov:wasDerivedFrom :AOPWikiXMLSource .

:AOPWikiXMLSource a prov:Entity ;
	rdfs:label "AOP-Wiki XML export" .

:geneDetectedByNER prov:wasGeneratedBy :BERN2NERMapping .
:geneDetectedByRegex prov:wasGeneratedBy :RegexGeneMapping .

