# SHACL Shape for Key Event Relationship
# Generated from property population audit
# Instances: 2291

shapes:KERShape
    a sh:NodeShape ;
    sh:targetClass aopo:KeyEventRelationship ;
    sh:name "Key Event Relationship" ;
    sh:property [
        sh:path aopo:has_downstream_key_event ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:name "aopo:has_downstream_key_event (100.0%)" ;
    ] ;
    sh:property [
        sh:path aopo:has_upstream_key_event ;
        sh:minCount 1 ;
