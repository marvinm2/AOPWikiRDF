@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix aopo: <http://aopkb.org/aop_ontology#> .
@prefix nci: <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#> .
@prefix cheminf: <http://semanticscience.org/resource/CHEMINF_> .
@prefix edam: <http://edamontology.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix ncbitaxon: <http://purl.bioontology.org/ontology/NCBITAXON/> .
@prefix pato: <http://purl.obolibrary.org/obo/PATO_> .
@prefix go: <http://purl.obolibrary.org/obo/GO_> .
@prefix mmo: <http://purl.obolibrary.org/obo/MMO_> .
@prefix hgnc: <https://identifiers.org/hgnc/> .
@prefix uniprot: <https://identifiers.org/uniprot/> .
@prefix ncbigene: <https://identifiers.org/ncbigene/> .
@prefix ensembl: <https://identifiers.org/ensembl/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix : <https://aopwiki.rdf.bigcat-bioinformatics.org/> .

@prefix shapes: <https://aopwiki.rdf.bigcat-bioinformatics.org/shapes/> .

# SHACL Shapes for Gene Association + BERN2 method provenance
# Generated from the flag-on fixture audit (data-test/gene-association-provenance-fixture.ttl)
# Typed gene-identifier subjects
# Instances: 6

shapes:GeneAssociationShape
    a sh:NodeShape ;
    sh:targetClass edam:data_1025 ;
    sh:name "Gene Association" ;
    sh:property [
        sh:path dc:identifier ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:name "dc:identifier (100.0%)" ;
    ] ;
    sh:property [
        sh:path dc:source ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:name "dc:source (100.0%)" ;
    ] ;
    sh:property [
        sh:path edam:data_2298 ;
        sh:severity sh:Warning ;
        sh:name "edam:data_2298 (50.0%)" ;
    ] ;
    sh:property [
        sh:path rdfs:label ;
        sh:severity sh:Warning ;
        sh:name "rdfs:label (50.0%)" ;
    ] ;
    sh:property [
        sh:path edam:data_1027 ;
        sh:severity sh:Warning ;
        sh:name "edam:data_1027 (16.7%)" ;
    ] ;
    sh:property [
        sh:path edam:data_1033 ;
        sh:severity sh:Warning ;
        sh:name "edam:data_1033 (16.7%)" ;
    ] ;
    sh:property [
        sh:path edam:data_2291 ;
        sh:severity sh:Warning ;
        sh:name "edam:data_2291 (16.7%)" ;
    ] ;
    sh:property [
        sh:path owl:sameAs ;
        sh:severity sh:Warning ;
        sh:name "owl:sameAs (16.7%)" ;
    ] ;
    sh:property [
        sh:path skos:exactMatch ;
        sh:severity sh:Warning ;
        sh:name "skos:exactMatch (16.7%)" ;
    ] ;
    .

# Untyped KE/KER union subjects; targeted via :geneDetectedBy* (no rdf:type in the genes file)
# Instances: 4

shapes:GeneMethodProvenanceShape
    a sh:NodeShape ;
    sh:targetSubjectsOf :geneDetectedByRegex ;
    sh:targetSubjectsOf :geneDetectedByNER ;
    sh:name "Gene Method Provenance (NER + regex union subjects)" ;
    sh:property [
        sh:path edam:data_1025 ;
        sh:severity sh:Warning ;
        sh:name "edam:data_1025 (50.0%)" ;
    ] ;
    sh:property [
        sh:path prov:wasGeneratedBy ;
        sh:severity sh:Warning ;
        sh:name "prov:wasGeneratedBy (50.0%)" ;
    ] ;
    sh:property [
        sh:path :geneDetectedByRegex ;
        sh:severity sh:Warning ;
        sh:name ":geneDetectedByRegex (50.0%)" ;
    ] ;
    sh:property [
        sh:path :geneDetectedByNER ;
        sh:severity sh:Warning ;
        sh:name ":geneDetectedByNER (25.0%)" ;
    ] ;
    .

# :isFeaturedMethod primacy + :minConfidence policy
# Instances: 2

shapes:MethodActivityShape
    a sh:NodeShape ;
    sh:targetClass prov:Activity ;
    sh:name "Gene Mapping Method Activity" ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:name "rdfs:label (100.0%)" ;
    ] ;
    sh:property [
        sh:path prov:used ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:name "prov:used (100.0%)" ;
    ] ;
    sh:property [
        sh:path prov:wasDerivedFrom ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:name "prov:wasDerivedFrom (100.0%)" ;
    ] ;
    sh:property [
        sh:path :isFeaturedMethod ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:name ":isFeaturedMethod (100.0%)" ;
    ] ;
    sh:property [
        sh:path :minConfidence ;
        sh:severity sh:Warning ;
        sh:name ":minConfidence (50.0%)" ;
    ] ;
    .
