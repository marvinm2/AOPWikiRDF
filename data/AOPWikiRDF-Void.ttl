@prefix : <https://aopwiki.rdf.bigcat-bioinformatics.org/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix void:  <http://rdfs.org/ns/void#> .
@prefix pav:   <http://purl.org/pav/> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcat:  <http://www.w3.org/ns/dcat#> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix freq:  <http://purl.org/cld/freq/> .
@prefix aop: <https://identifiers.org/aop/> .
@prefix aop.events: <https://identifiers.org/aop.events/> .
@prefix aop.relationships: <https://identifiers.org/aop.relationships/> .
@prefix aop.stressor: <https://identifiers.org/aop.stressor/> .
@prefix cas: <https://identifiers.org/cas/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

:AOPWikiRDF	a	void:Dataset, dcat:Dataset ;
	dc:description	"AOP-Wiki RDF -- complete dataset" ;
	dcterms:license	<https://creativecommons.org/licenses/by-sa/4.0/> ;
	void:sparqlEndpoint	<https://aopwiki.rdf.bigcat-bioinformatics.org/sparql/> ;
	void:dataDump	<https://raw.githubusercontent.com/marvinm2/AOPWikiRDF/master/data/AOPWikiRDF.ttl>, <https://raw.githubusercontent.com/marvinm2/AOPWikiRDF/master/data/AOPWikiRDF-Enriched.ttl>, <https://raw.githubusercontent.com/marvinm2/AOPWikiRDF/master/data/AOPWikiRDF-Genes.ttl> ;
	dcat:accrualPeriodicity	freq:quarterly ;
	void:subset	:AOPWikiRDF.ttl, :AOPWikiRDF-Enriched.ttl, :AOPWikiRDF-Genes.ttl ;
	void:exampleResource	aop:1, aop.events:1, aop.relationships:1, cas:83-79-4, aop.stressor:1 ;
	pav:createdOn	"2026-07-11"^^xsd:date ;
	pav:version	"1.3" ;
	foaf:homepage	<https://aopwiki.org> ;
	pav:createdBy	<https://zenodo.org/badge/latestdoi/146466058> .

:AOPWikiRDF.ttl	a	void:Dataset ;
	dc:description	"AOP-Wiki source-derived triples" ;
	void:triples	138042 ;
	dcterms:license	<https://creativecommons.org/licenses/by-sa/4.0/> ;
	pav:createdOn	"2026-07-11"^^xsd:date ;
	pav:createdWith	"aop-wiki-xml-2026-07-11", :Promapping ;
	foaf:homepage	<https://aopwiki.org> ;
	dcat:accrualPeriodicity	freq:quarterly ;
	dcat:downloadURL	<https://aopwiki.org/downloads/aop-wiki-xml-2026-07-11> .

:AOPWikiRDF-Enriched.ttl	a	void:Dataset ;
	dc:description	"Chemical and protein cross-reference enrichment triples" ;
	void:triples	8026 ;
	dcterms:license	<https://creativecommons.org/licenses/by-sa/4.0/> ;
	pav:importedFrom	<https://webservice.bridgedb.org/Human/> ;
	pav:createdOn	"2026-07-11"^^xsd:date .

:AOPWikiRDF-Genes.ttl	a	void:Dataset ;
	dc:description	"Gene mapping enrichment triples" ;
	void:triples	211613 ;
	dcterms:license	<https://creativecommons.org/licenses/by-sa/4.0/> ;
	pav:createdOn	"2026-07-11"^^xsd:date ;
	pav:createdWith	"aop-wiki-xml-2026-07-11", :HGNCgenes ;
	foaf:homepage	<https://aopwiki.org> ;
	dcat:accrualPeriodicity	freq:quarterly ;
	dcat:downloadURL	<https://aopwiki.org/downloads/aop-wiki-xml-2026-07-11>, <https://www.genenames.org/download/custom/> .

:HGNCgenes.txt	a	void:Dataset, void:Linkset ;
	dc:description	"HGNC approved symbols and names for genes" ;
	dcat:downloadURL	<https://www.genenames.org/download/custom/> ;
	pav:importedOn	"Sat Jul 11 09:39:39 2026" .

<https://proconsortium.org/download/current/promapping.txt>	a	void:Dataset, void:Linkset ;
	dc:description	"PRotein ontology mappings to protein database identifiers" ;
	dcat:downloadURL	<https://proconsortium.org/download/current/promapping.txt> ;
	pav:importedOn	"Sat Jul 11 09:39:36 2026" .
