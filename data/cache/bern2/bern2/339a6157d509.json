1204, "end": 1207}}, {"id": ["CHEBI:30158"], "is_neural_normalized": false, "mention": "BH4", "obj": "drug", "prob": 0.9984965324401855, "span": {"begin": 1249, "end": 1252}}, {"id": ["CHEBI:16111"], "is_neural_normalized": false, "mention": "4-HNE", "obj": "drug", "prob": 0.9992930889129639, "span": {"begin": 1275, "end": 1280}}, {"id": ["NCBIGene:4846"], "is_neural_normalized": false, "mention": "eNOS", "obj": "gene", "prob": 0.9846622943878174, "span": {"begin": 1291, "end": 1295}}, {"id": ["mesh:D009569"], "is_neural_normalized": false, "mention": "NO", "obj": "drug", "prob": null, "span": {"begin": 1309, "end": 1311}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "BAECs", "obj": "cell_type", "prob": 0.8240330815315247, "span": {"begin": 1326, "end": 1331}}, {"id": ["CHEBI:30158"], "is_neural_normalized": false, "mention": "BH4", "obj": "drug", "prob": 0.9973983764648438, "span": {"begin": 1389, "end": 1392}}, {"id": ["NCBIGene:4846"], "is_neural_normalized": false, "mention": "eNOS", "obj": "gene", "prob": 0.9902021884918213, "span": {"begin": 1411, "end": 1415}}, {"id": ["mesh:D013481"], "is_neural_normalized": false, "mention": "superoxide", "obj": "drug", "prob": 0.9996342658996582, "span": {"begin": 1425, "end": 1435}}, {"id": ["mesh:D009569"], "is_neural_normalized": false, "mention": "NO", "obj": "drug", "prob": null, "span": {"begin": 1461, "end": 1463}}, {"id": ["NCBITaxon:9913"], "is_neural_normalized": false, "mention": "bovine", "obj": "species", "prob": 0.9664508700370789, "span": {"begin": 1477, "end": 1483}}, {"id": ["NCBITaxon:10090"], "is_neural_normalized": false, "mention": "mouse", "obj": "species", "prob": 0.9012017846107483, "span": {"begin": 1485, "end": 1490}}, {"id": ["NCBITaxon:10116"], "is_neural_normalized": false, "mention": "rat", "obj": "species", "prob": 0.9465214610099792, "span": {"begin": 1496, "end": 1499}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "endothelial", "obj": "cell_type", "prob": 0.8594386577606201, "span": {"begin": 1665, "end": 1676}}, {"id": ["mesh:D002318"], "is_neural_normalized": false, "mention": "cardiovascular disease", "obj": "disease", "prob": 0.9997570514678955, "span": {"begin": 1689, "end": 1711}}, {"id": ["CHEBI:30158"], "is_neural_normalized": false, "mention": "BH4", "obj": "drug", "prob": 0.9978113770484924, "span": {"begin": 1733, "end": 1736}}, {"id": ["CHEBI:30158"], "is_neural_normalized": false, "mention": "BH4", "obj": "drug", "prob": 0.9980912804603577, "span": {"begin": 1778, "end": 1781}}, {"id": ["mesh:D006973"], "is_neural_normalized": false, "mention": "hypertensive", "obj": "disease", "prob": 0.9998928308486938, "span": {"begin": 1785, "end": 1797}}, {"id": ["NCBITaxon:9606"], "is_neural_normalized": false, "mention": "patients", "obj": "species", "prob": 0.9816587567329407, "span": {"begin": 1798, "end": 1806}}], "text": "BH4 is an essential cofactor for eNOS and is required for its enzymatic activity to produce NO. The depletion of BH4 leading to eNOS uncoupling is well-studied, thus there is strong biological plausibility for this link.  Two mouse studies showed limited BH4 availability induced eNOS uncoupling by reducing eNOS activity, leading to decreased nitric oxide and increased superoxide. In the mouse endothelial cell line sEnd.1, BH4 deficiency induced eNOS uncoupling as determined by superoxide production and impaired vasodilation (Crabtree et al., 2009). In primary aortic endothelial cells of GTPCH1-knockout mice, BH4 depletion significantly reduced eNOS activity, increased basal superoxide production and decreased NO bioactivity (Chuaiphichai et al., 2014). In rat hearts, BH4 content and eNOS activity were decreased in a time-dependent manner following myocardial ischemia with a marked decline after thirty minutes, while superoxide generation increased (Dumitrescu et al., 2007).  BAECs undergoing hypoxia and reoxygenation had decreased BH4 and decreased NO production, which was partially restored by treatment with the xanthine oxidase inhibitor oxypurinol, N-acetyl-l-cysteine (NAC) and NAC+BH4 (De Pascali et al., 2014). Inhibition of BH4 due to treatment with 4-HNE decreased eNOS activity and NO production in BAECs (Whitsett et al., 2007).  Many studies demonstrated that BH4 treatment reduced eNOS-mediated superoxide generation and increased NO formation in bovine, mouse, and rat endothelium (Chen et al., 2011; De Pascali et al., 2014; Landmesser et al., 2003; Ozaki et al., 2002; Shinozaki et al., 2000). Clinical studies reported improvement endothelial function in cardiovascular disease after treatment with BH4 (Wang et al., 2014). Oral treatment with BH4 in hypertensive patients significantly decreased blood pressure.", "timestamp": "Mon Jun 08 14:52:52 +0000 2026"}