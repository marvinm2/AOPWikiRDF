52, "end": 863}}, {"id": ["mesh:D001224"], "is_neural_normalized": false, "mention": "aspartate", "obj": "drug", "prob": 0.9932671189308167, "span": {"begin": 863, "end": 872}}, {"id": ["mesh:D016202"], "is_neural_normalized": false, "mention": "NMDA", "obj": "drug", "prob": 0.999679684638977, "span": {"begin": 874, "end": 878}}, {"id": ["NCBIGene:1627"], "is_neural_normalized": true, "mention": "drebrin", "obj": "gene", "prob": 0.8914207220077515, "span": {"begin": 904, "end": 911}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "dendritic", "obj": "cell_type", "prob": 0.5751446485519409, "span": {"begin": 924, "end": 933}}, {"id": ["mesh:D016202"], "is_neural_normalized": false, "mention": "NMDA", "obj": "drug", "prob": 0.9998306035995483, "span": {"begin": 979, "end": 983}}, {"id": ["mesh:D002122"], "is_neural_normalized": true, "mention": "CaCl", "obj": "drug", "prob": 0.9285621047019958, "span": {"begin": 1025, "end": 1029}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "drebrin", "obj": "DNA", "prob": 0.5144972801208496, "span": {"begin": 1065, "end": 1072}}, {"id": ["NCBIGene:1627"], "is_neural_normalized": true, "mention": "drebrin A", "obj": "gene", "prob": 0.9731909036636353, "span": {"begin": 1065, "end": 1074}}, {"id": ["NCBIGene:823"], "is_neural_normalized": true, "mention": "calpain", "obj": "gene", "prob": 0.9955630302429199, "span": {"begin": 1085, "end": 1092}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "40 kDa fragments", "obj": "RNA", "prob": 0.6804882884025574, "span": {"begin": 1203, "end": 1219}}, {"id": ["NCBIGene:831"], "is_neural_normalized": true, "mention": "calpain inhibitor-I", "obj": "gene", "prob": 0.9230340719223022, "span": {"begin": 1248, "end": 1267}}], "text": "Calcium modulates drebrin protein stability in neuronal cultures in ways that depend on both concentration and stimulus. NMDA receptor overactivation elevates intracellular calcium leads to loss of drebrin from dendritic spines of&nbsp;cultured coltcal neurons, hippocampal&nbsp;neurons and in vivo animal study.  &nbsp;Glutamate stimulation induced disappearance of drebrin immunostaining from dendritic spines but led to appearance of drebrin immunostaining in dendritic shafts and somata. The glutamate-induced shift of drebrin immunostaining was blocked by an NMDA receptor antagonist (Sekino, et al. 2006). Loss of drebrin from dendritic spines induced by hight-potasium stimulation or glutamate aplication was inhibited by EGTA and&nbsp;AP5 (Mizui, et al. 2014).&nbsp;&nbsp;Long term potentiation&nbsp;stimulation induces Ca2+&nbsp;entry through N-methyl-d-aspartate (NMDA) receptors, which causes drebrin exodus from dendritic spines (Koganezawa , et al 2017).&nbsp;Under NMDA-induced excitotoxic conditions with 1 mM CaCl, Chimura et al. (2015) report that drebrin A undergoes calpain-dependent degradation, with Western blotting and immunocytochemistry revealing the emergence of approximately 40 kDa fragments&mdash;a change prevented by calpain inhibitor-I.  &nbsp;  &nbsp;", "timestamp": "Mon Jun 08 15:56:35 +0000 2026"}