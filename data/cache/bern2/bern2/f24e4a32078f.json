malized": false, "mention": "interferon-gamma", "obj": "gene", "prob": 0.9648553729057312, "span": {"begin": 714, "end": 730}}, {"id": ["NCBIGene:3458"], "is_neural_normalized": false, "mention": "IFN-&gamma;", "obj": "gene", "prob": 0.9970746040344238, "span": {"begin": 732, "end": 743}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "B and plasma cells", "obj": "cell_type", "prob": 0.7620545625686646, "span": {"begin": 830, "end": 848}}, {"id": ["NCBIGene:7052"], "is_neural_normalized": true, "mention": "tissue transglutaminase 2", "obj": "gene", "prob": 0.991946816444397, "span": {"begin": 921, "end": 946}}, {"id": ["NCBIGene:7052"], "is_neural_normalized": false, "mention": "TG2", "obj": "gene", "prob": 0.9920971989631653, "span": {"begin": 948, "end": 951}}, {"id": ["mesh:D003424"], "is_neural_normalized": false, "mention": "CD", "obj": "disease", "prob": null, "span": {"begin": 1016, "end": 1018}}, {"id": ["NCBIGene:3600"], "is_neural_normalized": false, "mention": "IL-15", "obj": "gene", "prob": 0.9865343570709229, "span": {"begin": 1080, "end": 1085}}, {"id": ["mesh:D003424"], "is_neural_normalized": false, "mention": "CD", "obj": "disease", "prob": null, "span": {"begin": 1165, "end": 1167}}, {"id": ["NCBITaxon:9606"], "is_neural_normalized": false, "mention": "patients", "obj": "species", "prob": 0.9841225147247314, "span": {"begin": 1168, "end": 1176}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "intraepithelial lymphocytes", "obj": "cell_type", "prob": 0.9232096076011658, "span": {"begin": 1212, "end": 1239}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "IELs", "obj": "cell_line", "prob": 0.70147305727005, "span": {"begin": 1241, "end": 1245}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "IELs", "obj": "cell_line", "prob": 0.6314889192581177, "span": {"begin": 1254, "end": 1258}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "enterocytes", "obj": "cell_type", "prob": 0.8163110017776489, "span": {"begin": 1319, "end": 1330}}, {"id": ["mesh:C564019"], "is_neural_normalized": true, "mention": "villous atrophy", "obj": "disease", "prob": 0.9999994039535522, "span": {"begin": 1447, "end": 1462}}, {"id": ["mesh:C565627"], "is_neural_normalized": false, "mention": "diarrhea", "obj": "disease", "prob": 0.9999761581420898, "span": {"begin": 1712, "end": 1720}}, {"id": ["mesh:D015746"], "is_neural_normalized": false, "mention": "abdominal pain", "obj": "disease", "prob": 0.9992014765739441, "span": {"begin": 1722, "end": 1736}}, {"id": ["mesh:D008286"], "is_neural_normalized": false, "mention": "malabsorption", "obj": "disease", "prob": 0.999992847442627, "span": {"begin": 1738, "end": 1751}}, {"id": ["mesh:D005183"], "is_neural_normalized": false, "mention": "failure to thrive", "obj": "disease", "prob": 0.9999468922615051, "span": {"begin": 1753, "end": 1770}}, {"id": ["NCBITaxon:9606"], "is_neural_normalized": false, "mention": "children", "obj": "species", "prob": 0.9815139174461365, "span": {"begin": 1774, "end": 1782}}, {"id": ["mesh:D005221"], "is_neural_normalized": false, "mention": "fatigue", "obj": "disease", "prob": 0.9997500777244568, "span": {"begin": 1788, "end": 1795}}, {"id": ["NCBITaxon:9606"], "is_neural_normalized": false, "mention": "patients", "obj": "species", "prob": 0.9646722078323364, "span": {"begin": 1983, "end": 1991}}, {"id": ["mesh:D007410"], "is_neural_normalized": true, "mention": "intestinal damage", "obj": "disease", "prob": 0.9983302354812622, "span": {"begin": 2040, "end": 2057}}, {"id": ["mesh:D003424"], "is_neural_normalized": false, "mention": "CD", "obj": "disease", "prob": null, "span": {"begin": 2194, "end": 2196}}], "text": "Inflammation in the upper gastrointestinal tract is a hallmark of celiac disease (CD). This inflammation is characterized by a massive infiltration of lymphocytes in both the lamina propria and the epithelial layer of the small intestine (Sollid &amp; Jabri, 2013; Abadie &amp; Jabri, 2014). The density of antigen-presenting cells (APCs), including dendritic cells and macrophages, is significantly increased in the intestinal mucosa of CD patients, facilitating the activation of gluten-specific T cells (Di Niro et al., 2012; Jabri &amp; Sollid, 2009).  T cells specific for gluten peptides are readily detectable in the lamina propria. Upon activation, these T cells produce pro-inflammatory cytokines such as interferon-gamma (IFN-&gamma;), which perpetuate the inflammatory response (Sollid &amp; Jabri, 2013). In addition, B and plasma cells are abundant in the lamina propria and secrete autoantibodies targeting tissue transglutaminase 2 (TG2) and deamidated gluten peptides, which are hallmark features of CD pathogenesis (Di Niro et al., 2012; Schumann et al., 2012).  IL-15, a pro-inflammatory cytokine, is overexpressed in the intestinal epithelium of CD patients, contributing to the activation of intraepithelial lymphocytes (IELs). These IELs acquire cytolytic properties, leading to the destruction of enterocytes and disruption of the epithelial barrier (Abadie &amp; Jabri, 2014; McNab et al., 2015). This process culminates in villous atrophy, characterized by flattening of the intestinal villi, loss of barrier function, and reduced intestinal absorptive surface area (Abadie &amp; Jabri, 2014; Schumann et al., 2012). The resulting epithelial damage contributes to common symptoms such as diarrhea, abdominal pain, malabsorption, failure to thrive in children, and fatigue (Leonard et al., 2017).  The withdrawal of gluten from the diet typically results in the resolution of symptoms and normalization of intestinal morphology. Upon reintroduction of gluten, patients quickly experience a resurgence of symptoms and intestinal damage (Leonard et al., 2017; Sollid &amp; Jabri, 2013). Currently, a lifelong gluten-free diet (GFD) remains the only effective treatment for CD (Leonard et al., 2017; Fasano et al., 2012).", "timestamp": "Mon Jun 08 16:11:25 +0000 2026"}