gin": 1298, "end": 1306}}, {"id": ["NCBIGene:6713"], "is_neural_normalized": false, "mention": "squalene epoxidase", "obj": "gene", "prob": 0.9834150671958923, "span": {"begin": 1298, "end": 1316}}, {"id": ["mesh:D007810"], "is_neural_normalized": false, "mention": "lanosterol", "obj": "drug", "prob": 0.9981924891471863, "span": {"begin": 1318, "end": 1328}}, {"id": ["NCBIGene:4047"], "is_neural_normalized": true, "mention": "lanosterol synthase", "obj": "gene", "prob": 0.9678443670272827, "span": {"begin": 1318, "end": 1337}}, {"id": ["mesh:D007810"], "is_neural_normalized": false, "mention": "lanosterol", "obj": "drug", "prob": 0.9983906745910645, "span": {"begin": 1339, "end": 1349}}, {"id": ["NCBIGene:1595"], "is_neural_normalized": true, "mention": "lanosterol demethylase", "obj": "gene", "prob": 0.9738225340843201, "span": {"begin": 1339, "end": 1361}}, {"id": ["mesh:C016705"], "is_neural_normalized": false, "mention": "7-dehydro-cholesterol", "obj": "drug", "prob": 0.9672160148620605, "span": {"begin": 1367, "end": 1388}}, {"id": ["mesh:D002784"], "is_neural_normalized": false, "mention": "cholesterol", "obj": "drug", "prob": 0.9991195797920227, "span": {"begin": 1457, "end": 1468}}, {"id": ["NCBIGene:3638"], "is_neural_normalized": false, "mention": "INSIG1", "obj": "gene", "prob": 0.9435114860534668, "span": {"begin": 1477, "end": 1483}}, {"id": ["NCBIGene:22937"], "is_neural_normalized": false, "mention": "SCAP", "obj": "gene", "prob": 0.9852596521377563, "span": {"begin": 1493, "end": 1497}}, {"id": ["NCBIGene:22937"], "is_neural_normalized": false, "mention": "SCAP", "obj": "gene", "prob": 0.9899763464927673, "span": {"begin": 1539, "end": 1543}}, {"id": ["NCBIGene:26958"], "is_neural_normalized": true, "mention": "COPII", "obj": "gene", "prob": 0.9956851005554199, "span": {"begin": 1555, "end": 1560}}, {"id": ["NCBIGene:6720"], "is_neural_normalized": true, "mention": "SREBPs", "obj": "gene", "prob": 0.9836105108261108, "span": {"begin": 1589, "end": 1595}}, {"id": ["mesh:D002784"], "is_neural_normalized": false, "mention": "cholesterol", "obj": "drug", "prob": 0.9988669157028198, "span": {"begin": 1701, "end": 1712}}], "text": "Sterol Regulatory Element Binding Transcription Protein 2 (SREBP2) is synthesized as an inactive precursor protein, with inactive form located in the endoplasmic reticulum membrane (Horton et al. 2002). &nbsp;SREBP2 has an important role in lipid synthesis regulation. &nbsp;At low cholesterol levels, free SREBP cleavage-activating protein (SCAP) binds to Coat Protein Complex II (COPII; Ouyang et al. 2020). &nbsp;The SCAP-COPII complex enables Sterol Regulatory Element Binding Proteins (SREBPs) to move through the endoplasmic reticulum to the Golgi, where membrane-bound transcription factor site-1-protease (S1P) and site-2-protease (S2P) enable proteolytic processing that allows SREBPs to enter the nucleus (Yabe et al. 2002; Yang et al. 2002). &nbsp;In the nucleus, SREBP2 increases gene expression for enzymes involved in the mevalonate pathway of cholesterol synthesis (Sakakura et al. 2001; Ouyang et al. 2020; Itkonen et al., 2023) including not only rate-limited enzymes including 3-hydroxy-3-methylglutarylcoenzyme (HMGCR) (Sakakura et al. 2001; Itkonen et al. 2023) but many enzymes in the pathway: mevalonate kinase, mevalonate pyrophosphate decarboxylase, isopentenyl phosphate isomerase, geranylgeranyl pyrophosphate synthase, farnesyl pyrophosphate synthase, squalene synthase, squalene epoxidase, lanosterol synthase, lanosterol demethylase, and 7-dehydro-cholesterol reductase (Sakakura et al. 2001; Horton et al. 2002). &nbsp;At high cholesterol levels, INSIG1 binds to SCAP, competitively inhibiting the ability of SCAP to bind to COPII (Ouyang et al. 2020). &nbsp;SREBPs are retained in the endoplasmic reticulum rather than being transferred to the Golgi, reducing levels of cholesterol synthesis (Ouyang et al. 2020; Itkonen et al., 2023).&nbsp;", "timestamp": "Mon Jun 08 16:14:23 +0000 2026"}