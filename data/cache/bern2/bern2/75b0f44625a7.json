": "drug", "prob": 0.9971885681152344, "span": {"begin": 639, "end": 650}}, {"id": ["mesh:D005690"], "is_neural_normalized": false, "mention": "galactose", "obj": "drug", "prob": 0.998738706111908, "span": {"begin": 661, "end": 670}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "avian", "obj": "species", "prob": 0.5816123485565186, "span": {"begin": 694, "end": 699}}, {"id": ["NCBITaxon:9606"], "is_neural_normalized": false, "mention": "human", "obj": "species", "prob": 0.9816511869430542, "span": {"begin": 866, "end": 871}}, {"id": ["mesh:D012794"], "is_neural_normalized": false, "mention": "sialic acids", "obj": "drug", "prob": 0.989237904548645, "span": {"begin": 959, "end": 971}}, {"id": ["mesh:D012794"], "is_neural_normalized": false, "mention": "sialic acids", "obj": "drug", "prob": 0.9963484406471252, "span": {"begin": 1034, "end": 1046}}, {"id": ["mesh:D012794"], "is_neural_normalized": false, "mention": "sialic acids", "obj": "drug", "prob": 0.9675002694129944, "span": {"begin": 1153, "end": 1165}}, {"id": ["NCBITaxon:9606"], "is_neural_normalized": false, "mention": "humans", "obj": "species", "prob": 0.9804603457450867, "span": {"begin": 1176, "end": 1182}}, {"id": ["mesh:D012794"], "is_neural_normalized": false, "mention": "sialic acids", "obj": "drug", "prob": 0.8650944232940674, "span": {"begin": 1383, "end": 1395}}, {"id": ["mesh:D012794"], "is_neural_normalized": false, "mention": "sialic acids", "obj": "drug", "prob": 0.9928025603294373, "span": {"begin": 1504, "end": 1516}}, {"id": ["NCBIGene:23526"], "is_neural_normalized": true, "mention": "hemagglutinin", "obj": "gene", "prob": 0.992510199546814, "span": {"begin": 1619, "end": 1632}}, {"id": ["NCBIGene:23526"], "is_neural_normalized": true, "mention": "HA", "obj": "gene", "prob": 0.9996566772460938, "span": {"begin": 1634, "end": 1636}}, {"id": ["mesh:D019158"], "is_neural_normalized": false, "mention": "sialic acid", "obj": "drug", "prob": 0.9946999549865723, "span": {"begin": 1656, "end": 1667}}, {"id": ["CHEBI:28659"], "is_neural_normalized": false, "mention": "phosphor", "obj": "drug", "prob": 0.9674549102783203, "span": {"begin": 1886, "end": 1894}}, {"id": ["NCBIGene:51284"], "is_neural_normalized": true, "mention": "IAV receptor7", "obj": "gene", "prob": 0.9109734296798706, "span": {"begin": 1931, "end": 1944}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "IAV", "obj": "species", "prob": 0.686089277267456, "span": {"begin": 1931, "end": 1934}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "IAV", "obj": "species", "prob": 0.5827885866165161, "span": {"begin": 1976, "end": 1979}}, {"id": ["NCBIGene:3118", "3132", "3128"], "is_neural_normalized": true, "mention": "MHC class II", "obj": "gene", "prob": 0.9956017136573792, "span": {"begin": 2057, "end": 2069}}], "text": "Sialic acid was one of the first viral receptors identified5. Humans have 6 sialyl transferases that catalyze the addition of Sia with an a2,3 linkage to terminal galactose residues and 2 that catalyze the addition of an a2,6 linkage to terminal galactose residues6.  &nbsp;  The HA receptor of the IAV attaches to the surface of the host cell via glycoconjugates that contain terminal sialic acid residues. The virus then &ldquo;scans&rdquo; the surface of the cell for the correct receptor, using its NA to remove nonproductive HA associations. The exact receptor is currently unknown however human influenza viruses preferentially bind sialic acid linked to galactose by a2,6 linkage, while avian influenza viruses prefer a2,3 linkages1. However, most viruses are not this dichotomous and the ability to bind sialic acid is more of a spectrum2. Additionally, the human respiratory tract contains both types of linkages as a gradient, with more a2,6 linked sialic acids present in the upper airway transitioning to more a2,3 linked sialic acids in the lower airway3. Some avian viruses can only replicate effectively in cells that express a2,3 linked sialic acids, which in humans is limited to the lower respiratory tract, which may serve as barrier to interspecies transmission and require that successful zoonosis is contingent upon the ability of the virus to bind a2,6 linked sialic acids, making this a marker of pandemic potential3. However, this is complicated by new evidence that non-binding sialic acids can contribute to enhanced binding and infection through hetero-multivalent interactions4. Individual hemagglutinin (HA) interactions with sialic acid glycan receptors are low affinity (KD ~0,5 to 20mM) leading to a low initial binding rate but high avidity is achieved through multivalent interactions with a receptor coated surface4.  &nbsp;  Recent findings suggest phosphor-glycans are a potential alternative IAV receptor7. Additionally, two subtypes of IAV found exclusively in South and Central American bats (H17N10 and H18N11) use MHC class II for entry7,8.", "timestamp": "Fri May 15 21:59:07 +0000 2026"}