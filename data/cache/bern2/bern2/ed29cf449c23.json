n": "msi2b", "obj": "gene", "prob": 0.9983128309249878, "span": {"begin": 412, "end": 417}}, {"id": ["NCBIGene:4762"], "is_neural_normalized": false, "mention": "neurog1", "obj": "gene", "prob": 0.9971628785133362, "span": {"begin": 419, "end": 426}}, {"id": ["NCBIGene:5455"], "is_neural_normalized": true, "mention": "pou5f3", "obj": "gene", "prob": 0.9837427735328674, "span": {"begin": 437, "end": 443}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "Group", "obj": "DNA", "prob": 0.7900791168212891, "span": {"begin": 445, "end": 450}}, {"id": ["NCBIGene:2188"], "is_neural_normalized": true, "mention": "Group F", "obj": "gene", "prob": 0.8568743467330933, "span": {"begin": 445, "end": 452}}, {"id": ["NCBIGene:161198"], "is_neural_normalized": true, "mention": "her5", "obj": "gene", "prob": 0.9900471568107605, "span": {"begin": 454, "end": 458}}, {"id": ["NCBIGene:2299"], "is_neural_normalized": false, "mention": "foxi1", "obj": "gene", "prob": 0.9954042434692383, "span": {"begin": 460, "end": 465}}, {"id": ["NCBIGene:7190"], "is_neural_normalized": false, "mention": "hsp", "obj": "gene", "prob": 0.9977164268493652, "span": {"begin": 508, "end": 511}}, {"id": ["NCBIGene:2637"], "is_neural_normalized": false, "mention": "gbx2+", "obj": "gene", "prob": 0.9722108840942383, "span": {"begin": 512, "end": 517}}, {"id": ["NCBIGene:5015"], "is_neural_normalized": false, "mention": "otx2", "obj": "gene", "prob": 0.9979705810546875, "span": {"begin": 783, "end": 787}}, {"id": ["NCBIGene:5015"], "is_neural_normalized": true, "mention": "otx1b", "obj": "gene", "prob": 0.9982354640960693, "span": {"begin": 789, "end": 794}}, {"id": ["NCBIGene:161198"], "is_neural_normalized": true, "mention": "her5", "obj": "gene", "prob": 0.9919220209121704, "span": {"begin": 796, "end": 800}}, {"id": ["NCBIGene:8820"], "is_neural_normalized": false, "mention": "hesx1", "obj": "gene", "prob": 0.996179461479187, "span": {"begin": 802, "end": 807}}, {"id": ["NCBIGene:10365"], "is_neural_normalized": true, "mention": "klf2a", "obj": "gene", "prob": 0.9948198199272156, "span": {"begin": 809, "end": 814}}, {"id": ["NCBIGene:5455"], "is_neural_normalized": true, "mention": "pou5f3", "obj": "gene", "prob": 0.994277834892273, "span": {"begin": 820, "end": 826}}, {"id": ["NCBIGene:2637"], "is_neural_normalized": false, "mention": "gbx2", "obj": "gene", "prob": 0.9859583973884583, "span": {"begin": 1071, "end": 1075}}], "text": "Foxi1 is one of the downstream genes regulated by gbx2 transcription factor. Downregulation of gbx2 leads to increased foxi1 expression in zebrafish embryos.    (Nakayama et al., 2017) sought to comprehensively identify the target genes of zebrafish gbx2 at the end of gastrulation by microarray analysis. Eight genes that had been shown by the microarray data to be downregulated (Group C, otx1b, otx2, hoxb5b, msi2b, neurog1; Group D, pou5f3; Group F, her5, foxi1) were indeed immediately downregulated in hsp-gbx2+ embryos. Most of the genes that were identified as upregulated or downregulated in the microarray analysis were confirmed by qPCR analysis. WISH (whole mount in situ hybridization) further confirmed the alterations in expression for 6 out of the 12 genes examined (otx2, otx1b, her5, hesx1, klf2a, and pou5f3). Failure to detect the expression alterations of the remaining genes with WISH is likely due to the non-quantitative nature of the WISH technique, which can only detect marked differences in expression levels. It is additionally possible that gbx2 induction affected broad and low-level expression that was undetectable by their conventional WISH technique. Still, the qPCR and WISH results together confirmed the reliability of the comprehensive microarray analysis (Nakayama et al., 2017).", "timestamp": "Mon Jun 08 15:36:39 +0000 2026"}