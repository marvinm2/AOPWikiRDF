": 449, "end": 477}}, {"id": ["NCBIGene:3118"], "is_neural_normalized": true, "mention": "HLA-DQ2/8 molecules", "obj": "gene", "prob": 0.9882190823554993, "span": {"begin": 517, "end": 536}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "antigen-presenting cells", "obj": "cell_type", "prob": 0.6017799377441406, "span": {"begin": 540, "end": 564}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "APCs", "obj": "cell_type", "prob": 0.8032280206680298, "span": {"begin": 566, "end": 570}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "T cells", "obj": "cell_type", "prob": 0.7669727802276611, "span": {"begin": 611, "end": 618}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "B cells", "obj": "cell_type", "prob": 0.5281477570533752, "span": {"begin": 650, "end": 657}}, {"id": ["NCBIGene:7052"], "is_neural_normalized": true, "mention": "TG2-gluten complexes", "obj": "gene", "prob": 0.7393388152122498, "span": {"begin": 705, "end": 725}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "T", "obj": "cell_type", "prob": 0.8836777210235596, "span": {"begin": 731, "end": 732}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "plasma cells", "obj": "cell_type", "prob": 0.46767833828926086, "span": {"begin": 820, "end": 832}}, {"id": ["NCBIGene:973"], "is_neural_normalized": true, "mention": "IgA autoantibodies", "obj": "gene", "prob": 0.994921863079071, "span": {"begin": 843, "end": 861}}, {"id": ["NCBIGene:7052"], "is_neural_normalized": false, "mention": "TG2", "obj": "gene", "prob": 0.9919811487197876, "span": {"begin": 870, "end": 873}}, {"id": ["NCBIGene:2638"], "is_neural_normalized": true, "mention": "IgG antibodies", "obj": "gene", "prob": 0.9830859303474426, "span": {"begin": 878, "end": 892}}], "text": "B cells require direct interaction with antigen-specific helper T cells for activation (Lanzavecchia, 1985). This interaction is facilitated by the antigen serving as a bridge, allowing the T cell receptor (TCR) on T cells to engage with the peptide-MHC complex on B cells. Such antigen-specific T-B cell cooperation is crucial for initiating and sustaining adaptive immune responses, including those observed in celiac disease.  In celiac disease, gluten-reactive CD4+ T cells recognize gluten peptides presented by HLA-DQ2/8 molecules on antigen-presenting cells (APCs) (Koning et al., 2015). These activated T cells then provide essential help to B cells that have internalized and processed gluten or TG2-gluten complexes. The T-B cell interaction leads to B cell activation, proliferation, and differentiation into plasma cells secreting IgA autoantibodies against TG2 and IgG antibodies against deamidated gliadin.&nbsp;  &nbsp;", "timestamp": "Mon Jun 08 16:11:15 +0000 2026"}