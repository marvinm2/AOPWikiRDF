36, "end": 839}}, {"id": ["NCBIGene:5054"], "is_neural_normalized": false, "mention": "PAI-1", "obj": "gene", "prob": 0.9939874410629272, "span": {"begin": 874, "end": 879}}, {"id": ["NCBIGene:5327"], "is_neural_normalized": false, "mention": "tPA", "obj": "gene", "prob": 0.9971293807029724, "span": {"begin": 915, "end": 918}}, {"id": ["NCBIGene:5328"], "is_neural_normalized": false, "mention": "uPA", "obj": "gene", "prob": 0.9961546659469604, "span": {"begin": 919, "end": 922}}, {"id": ["NCBIGene:3827"], "is_neural_normalized": false, "mention": "Bradykinin", "obj": "gene", "prob": 0.9753127098083496, "span": {"begin": 986, "end": 996}}, {"id": ["NCBIGene:5327"], "is_neural_normalized": false, "mention": "tPA", "obj": "gene", "prob": 0.9895197153091431, "span": {"begin": 1015, "end": 1018}}, {"id": ["NCBIGene:5054"], "is_neural_normalized": false, "mention": "PAI-1", "obj": "gene", "prob": 0.9960848093032837, "span": {"begin": 1030, "end": 1035}}, {"id": ["mesh:D000086382"], "is_neural_normalized": false, "mention": "COVID-19", "obj": "disease", "prob": 0.9999151825904846, "span": {"begin": 1055, "end": 1063}}, {"id": ["NCBITaxon:9606"], "is_neural_normalized": false, "mention": "patients", "obj": "species", "prob": 0.628373384475708, "span": {"begin": 1064, "end": 1072}}, {"id": ["NCBIGene:5054"], "is_neural_normalized": false, "mention": "PAI-1", "obj": "gene", "prob": 0.9916788935661316, "span": {"begin": 1078, "end": 1083}}, {"id": ["NCBIGene:5327"], "is_neural_normalized": false, "mention": "tPA", "obj": "gene", "prob": 0.9914653897285461, "span": {"begin": 1116, "end": 1119}}, {"id": ["mesh:D000347"], "is_neural_normalized": true, "mention": "hypofibrinolysis", "obj": "disease", "prob": 0.9999195337295532, "span": {"begin": 1132, "end": 1148}}, {"id": ["NCBIGene:3827"], "is_neural_normalized": false, "mention": "Bradykinin", "obj": "gene", "prob": 0.950401782989502, "span": {"begin": 1168, "end": 1178}}, {"id": ["NCBIGene:3569"], "is_neural_normalized": false, "mention": "IL6", "obj": "gene", "prob": 0.9702796339988708, "span": {"begin": 1315, "end": 1318}}, {"id": ["NCBIGene:5054"], "is_neural_normalized": false, "mention": "PAI-1", "obj": "gene", "prob": 0.9819959402084351, "span": {"begin": 1402, "end": 1407}}, {"id": ["mesh:D000347"], "is_neural_normalized": true, "mention": "hypofibrinolysis", "obj": "disease", "prob": 0.9999725818634033, "span": {"begin": 1442, "end": 1458}}], "text": "Bradykinin (BK) plays an important role in the kinin-kallikrein system (KKS) as a regulator of blood pressure and can induce vasodilation, increase blood flow, as well as hypotension. BK is also an important part of the inflammatory process after injury, inducing pain stimulation. Activation of the BK system is associated with vasodilation and vascular leakage, allowing for infiltration of proinflammatory cells such as IL6 ((Hofman et al, 2016).  During SARS-CoV-2 infection, increased activity of kallikrein activates the bradykinin system. Bradykinin is known to stimulate tissue plasminogen activator (tPA), a protein that increases fibrinolysis. However, ACE2 downregulation from SARS-COV-2 infection increases Angiotensin 1 and II (ANG 1 and ANGII), which increases Plasminogen activator inhibitor (PAI-1) levels and decreases tPA levels (Mogielnicki et al, 2014). PAI-1 inhibits the protective effects of tPA/uPA in fibrinolysis, decreasing fibrinolysis. Data shows that both Bradykinin, and subsequently tPA levels and PAI-1 levels increase in COVID-19 patients, but PAI-1 increases at a higher rate than tPA, leading to hypofibrinolysis(Zuo et al, 2021).  Bradykinin, as a result of its role as a vasodilator, increases vascular permeability, which increases levels of proinflammatory mediators such as IL6 (Sprague et al, 2009). These proinflammatory mediators have been found to increase PAI-1 levels, which ultimately leads to hypofibrinolysis(Kang et al, 2020. Rega et al, 2020).", "timestamp": "Mon Jun 08 15:34:09 +0000 2026"}