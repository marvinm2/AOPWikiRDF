0.972873866558075, "span": {"begin": 1287, "end": 1324}}, {"id": ["mesh:C004808"], "is_neural_normalized": false, "mention": "farnesyl pyrophosphate", "obj": "drug", "prob": 0.9951189160346985, "span": {"begin": 1326, "end": 1348}}, {"id": ["NCBIGene:2224"], "is_neural_normalized": true, "mention": "farnesyl pyrophosphate synthase", "obj": "gene", "prob": 0.9726054072380066, "span": {"begin": 1326, "end": 1357}}, {"id": ["mesh:D013185"], "is_neural_normalized": false, "mention": "squalene", "obj": "drug", "prob": 0.9996843338012695, "span": {"begin": 1359, "end": 1367}}, {"id": ["NCBIGene:2222"], "is_neural_normalized": true, "mention": "squalene synthase", "obj": "gene", "prob": 0.9703699350357056, "span": {"begin": 1359, "end": 1376}}, {"id": ["mesh:D013185"], "is_neural_normalized": false, "mention": "squalene", "obj": "drug", "prob": 0.9991064667701721, "span": {"begin": 1378, "end": 1386}}, {"id": ["NCBIGene:6713"], "is_neural_normalized": false, "mention": "squalene epoxidase", "obj": "gene", "prob": 0.9927282333374023, "span": {"begin": 1378, "end": 1396}}, {"id": ["mesh:D007810"], "is_neural_normalized": false, "mention": "lanosterol", "obj": "drug", "prob": 0.9988985061645508, "span": {"begin": 1398, "end": 1408}}, {"id": ["NCBIGene:4047"], "is_neural_normalized": true, "mention": "lanosterol synthase", "obj": "gene", "prob": 0.9725354313850403, "span": {"begin": 1398, "end": 1417}}, {"id": ["mesh:D007810"], "is_neural_normalized": false, "mention": "lanosterol", "obj": "drug", "prob": 0.9991180300712585, "span": {"begin": 1419, "end": 1429}}, {"id": ["NCBIGene:1595"], "is_neural_normalized": true, "mention": "lanosterol demethylase", "obj": "gene", "prob": 0.9824644923210144, "span": {"begin": 1419, "end": 1441}}, {"id": ["mesh:C016705"], "is_neural_normalized": false, "mention": "7-dehydro-cholesterol", "obj": "drug", "prob": 0.9901766777038574, "span": {"begin": 1447, "end": 1468}}, {"id": ["NCBIGene:1717"], "is_neural_normalized": false, "mention": "7-dehydro-cholesterol reductase", "obj": "gene", "prob": 0.983582079410553, "span": {"begin": 1447, "end": 1478}}, {"id": ["mesh:D002784"], "is_neural_normalized": false, "mention": "cholesterol", "obj": "drug", "prob": 0.999261200428009, "span": {"begin": 1537, "end": 1548}}, {"id": ["NCBIGene:3638"], "is_neural_normalized": false, "mention": "INSIG1", "obj": "gene", "prob": 0.97237229347229, "span": {"begin": 1557, "end": 1563}}, {"id": ["NCBIGene:22937"], "is_neural_normalized": false, "mention": "SCAP", "obj": "gene", "prob": 0.9894950985908508, "span": {"begin": 1573, "end": 1577}}, {"id": ["NCBIGene:22937"], "is_neural_normalized": false, "mention": "SCAP", "obj": "gene", "prob": 0.9928058981895447, "span": {"begin": 1619, "end": 1623}}, {"id": ["NCBIGene:26958"], "is_neural_normalized": true, "mention": "COPII", "obj": "gene", "prob": 0.9907180666923523, "span": {"begin": 1635, "end": 1640}}, {"id": ["NCBIGene:6720"], "is_neural_normalized": true, "mention": "SREBPs", "obj": "gene", "prob": 0.9935798048973083, "span": {"begin": 1669, "end": 1675}}, {"id": ["mesh:D002784"], "is_neural_normalized": false, "mention": "cholesterol", "obj": "drug", "prob": 0.9984169006347656, "span": {"begin": 1781, "end": 1792}}], "text": "Sterol Regulatory Element Binding Transcription Protein 2 (SREBP2) is synthesized as an inactive precursor protein, with inactive form located in the endoplasmic reticulum membrane (Horton et al. 2002). &nbsp;SREBP2 has an important role in lipid synthesis regulation. &nbsp;At low cholesterol levels, insulin-induced gene 1 (INSIG1) has lower binding affinity for SREBP cleavage-activating protein (SCAP), allowing free SCAP to bind to Coat Protein Complex II (COPII; Ouyang et al. 2020). &nbsp;The SCAP-COPII complex enables Sterol Regulatory Element Binding Proteins (SREBPs) to move through the endoplasmic reticulum to the Golgi, where membrane-bound transcription factor site-1-protease (S1P) and site-2-protease (S2P) enable proteolytic processing that allows SREBPs to enter the nucleus (Yabe et al. 2022; Yang et al. 2022). &nbsp;In the nucleus, SREBP2 increases gene expression for enzymes involved in the mevalonate pathway of cholesterol synthesis (Sakakura et al. 2001; Ouyang et al. 2020; Itkonen et al., 2023) including not only rate-limited enzymes including 3-hydroxy-3-methylglutarylcoenzyme (HMGCR) (Sakakura et al. 2001; Itkonen et al. 2023) but many enzymes in the pathway: mevalonate kinase, mevalonate pyrophosphate decarboxylase, isopentenyl phosphate isomerase, geranylgeranyl pyrophosphate synthase, farnesyl pyrophosphate synthase, squalene synthase, squalene epoxidase, lanosterol synthase, lanosterol demethylase, and 7-dehydro-cholesterol reductase (Sakakura et al. 2001; Horton et al. 2002). &nbsp;At high cholesterol levels, INSIG1 binds to SCAP, competitively inhibiting the ability of SCAP to bind to COPII (Ouyang et al. 2020). &nbsp;SREBPs are retained in the endoplasmic reticulum rather than being transferred to the Golgi, reducing levels of cholesterol synthesis (Ouyang et al. 2020; Itkonen et al., 2023).&nbsp;", "timestamp": "Fri May 15 22:00:57 +0000 2026"}