j": "gene", "prob": 0.9317091703414917, "span": {"begin": 295, "end": 299}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "macrophages", "obj": "cell_type", "prob": 0.6543272137641907, "span": {"begin": 310, "end": 321}}, {"id": ["NCBIGene:2099"], "is_neural_normalized": false, "mention": "ER&alpha;", "obj": "gene", "prob": 0.9789078831672668, "span": {"begin": 401, "end": 410}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "activated PBMC subsets", "obj": "cell_line", "prob": 0.4941328763961792, "span": {"begin": 437, "end": 459}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "PBMC subsets", "obj": "cell_type", "prob": 0.7354484796524048, "span": {"begin": 447, "end": 459}}, {"id": ["NCBIGene:2099"], "is_neural_normalized": false, "mention": "ER&alpha", "obj": "gene", "prob": 0.9728631973266602, "span": {"begin": 475, "end": 483}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "thymocytes", "obj": "cell_type", "prob": 0.8222450613975525, "span": {"begin": 519, "end": 529}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "CD4+ T cells", "obj": "cell_line", "prob": 0.7584161758422852, "span": {"begin": 531, "end": 543}}, {"id": ["NCBIGene:920"], "is_neural_normalized": false, "mention": "CD4+", "obj": "gene", "prob": 0.7795327305793762, "span": {"begin": 531, "end": 535}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "B cells", "obj": "cell_type", "prob": 0.8003121018409729, "span": {"begin": 549, "end": 556}}, {"id": ["NCBIGene:2099"], "is_neural_normalized": false, "mention": "ER&alpha", "obj": "gene", "prob": 0.8486685752868652, "span": {"begin": 582, "end": 590}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "estrogen response elements", "obj": "DNA", "prob": 0.8948971629142761, "span": {"begin": 732, "end": 758}}, {"id": ["mesh:D004967"], "is_neural_normalized": false, "mention": "estrogen", "obj": "drug", "prob": 0.9813932776451111, "span": {"begin": 732, "end": 740}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "ERE", "obj": "DNA", "prob": 0.8915508985519409, "span": {"begin": 760, "end": 763}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "ERE", "obj": "DNA", "prob": 0.5688877105712891, "span": {"begin": 772, "end": 775}}, {"id": ["CUI-less"], "is_neural_normalized": false, "mention": "target genes", "obj": "DNA", "prob": 0.7125873565673828, "span": {"begin": 814, "end": 826}}], "text": "ER&alpha; is expressed in all vertebrates (Eick GN. 2011).&nbsp; ER&alpha; was discovered in the late 1960s and was cloned and characterized in 1985 (Melissa C. 2011). &nbsp;ER&alpha; is expressed in a variety of immunocompetent cells, including thymocytes, CD4+ (Th1, Th2, Th17, and Tregs) and CD8+ cells and macrophages (Melissa C. 2011, Salem ML. 2004, Robinson DP. 2014).&nbsp; One study examined ER&alpha; expression in resting and activated PBMC subsets and found that ER&alpha; was expressed at higher levels in thymocytes, CD4+ T cells than B cells (Melissa C. 2011).&nbsp; ER&alpha; is a nuclear hormone transcription factor that classically binds with ligand (stressors), further stabilizing dimers that subsequently bind estrogen response elements (ERE) or non-ERE to transactivate or suppress specific target genes (Parker MG. 1993, Goldstein RA. 1993, Sasson S. 1991, Brandt ME. 1997, Carolyn MK. 2001).", "timestamp": "Fri May 15 21:22:37 +0000 2026"}